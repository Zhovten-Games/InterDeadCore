{
  "name": "@interdead/framework",
  "version": "0.1.0",
  "description": "InterDead UI framework runtime with modular feature loading and host-agnostic config adapters.",
  "type": "module",
  "main": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./browser": {
      "default": "./dist/browser/interdead-framework.global.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:browser",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:browser": "esbuild src/index.ts --bundle --format=iife --global-name=InterdeadFramework --platform=browser --outfile=dist/browser/interdead-framework.global.js",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "interdead",
    "framework",
    "membrane",
    "hexagonal"
  ],
  "author": "InterDead Core",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.10.1",
    "prettier": "^3.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "esbuild": "^0.25.0"
  }
}
